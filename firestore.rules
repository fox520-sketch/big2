rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function sameRoomId(roomId) {
      return request.resource.data.roomId == roomId && resource.data.roomId == roomId;
    }

    function validRoomKeys() {
      return request.resource.data.keys().hasOnly([
        'roomId', 'status', 'hostUid', 'hostName', 'aiLevel', 'rules', 'scoringRules',
        'securityVersion', 'version', 'createdAt', 'updatedAt', 'presenceUpdatedAt',
        'invitePath', 'gameNo', 'lastEvent', 'seats', 'game', 'totalScores',
        'passwordEnabled', 'passwordHash', 'passwordHint'
      ]);
    }

    function seatOwnedBy(data, key) {
      return data.seats.keys().hasAny([key]) && data.seats[key].uid == request.auth.uid;
    }

    function isRoomMember(data) {
      return seatOwnedBy(data, '0') || seatOwnedBy(data, '1')
        || seatOwnedBy(data, '2') || seatOwnedBy(data, '3');
    }

    function joinKeepsProtectedFields() {
      return request.resource.data.roomId == resource.data.roomId
        && request.resource.data.status == resource.data.status
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.hostName == resource.data.hostName
        && request.resource.data.aiLevel == resource.data.aiLevel
        && request.resource.data.rules == resource.data.rules
        && request.resource.data.scoringRules == resource.data.scoringRules
        && request.resource.data.securityVersion == resource.data.securityVersion
        && request.resource.data.version == resource.data.version
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.invitePath == resource.data.invitePath
        && request.resource.data.get('gameNo', 0) == resource.data.get('gameNo', 0)
        && request.resource.data.get('passwordEnabled', false) == resource.data.get('passwordEnabled', false)
        && request.resource.data.get('passwordHash', '') == resource.data.get('passwordHash', '')
        && request.resource.data.get('passwordHint', '') == resource.data.get('passwordHint', '')
        // 等待中的房間可能尚未建立 game 欄位；使用 get() 避免讀取不存在欄位時拒絕加入。
        && request.resource.data.get('game', null) == resource.data.get('game', null);
    }

    function validNewMemberJoin() {
      return !isRoomMember(resource.data)
        && isRoomMember(request.resource.data)
        && (resource.data.status == 'waiting' || resource.data.status == 'finished')
        && joinKeepsProtectedFields()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'seats', 'totalScores', 'updatedAt', 'presenceUpdatedAt', 'lastEvent'
        ])
        && request.resource.data.seats.diff(resource.data.seats).affectedKeys().size() == 1;
    }

    match /rooms/{roomId} {
      // 加入房間前必須能以房號讀取房間，因此朋友休閒版仍允許所有匿名登入者讀取。
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.roomId == roomId
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting'
        && isRoomMember(request.resource.data)
        && validRoomKeys();

      // 只有既有房內成員，或在等待／結束狀態加入單一座位的新玩家可以更新。
      // 牌型與回合合法性仍由前端 transaction 驗證；真正不可繞過的防作弊仍需要可信任後端。
      allow update: if signedIn()
        && sameRoomId(roomId)
        && validRoomKeys()
        && (isRoomMember(resource.data) || validNewMemberJoin());

      allow delete: if signedIn()
        && isRoomMember(resource.data)
        && resource.data.hostUid == request.auth.uid;
    }
  }
}
