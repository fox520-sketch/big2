rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function sameRoomId(roomId) {
      return request.resource.data.roomId == roomId && resource.data.roomId == roomId;
    }

    function validRoomKeys() {
      return request.resource.data.keys().hasOnly([
        'roomId', 'status', 'hostUid', 'hostName', 'aiLevel', 'rules', 'scoringRules',
        'securityVersion', 'version', 'createdAt', 'updatedAt', 'presenceUpdatedAt',
        'invitePath', 'gameNo', 'lastEvent', 'seats', 'game', 'totalScores',
        'passwordEnabled', 'passwordHash', 'passwordHint'
      ]);
    }

    match /rooms/{roomId} {
      allow read: if signedIn();

      // v0.6.7 朋友休閒版安全規則：
      // 1. 僅允許登入玩家讀寫房間。
      // 2. 限制房間文件欄位，避免寫入未預期資料。
      // 3. 前端交易會再驗證目前座位、回合、手牌與 revision。
      // 4. 若要正式防作弊，請改用 Cloud Functions 洗牌、發牌與驗證出牌。
      allow create: if signedIn()
        && request.resource.data.roomId == roomId
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting'
        && validRoomKeys();

      allow update: if signedIn()
        && sameRoomId(roomId)
        && validRoomKeys();

      allow delete: if signedIn() && resource.data.hostUid == request.auth.uid;
    }
  }
}
