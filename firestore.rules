rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /rooms/{roomId} {
      // v0.7.0 正式防作弊版：
      // 用戶端只能讀取房間狀態；建立房間、加入房間、補 AI、開始遊戲、出牌、Pass、AI 接管、離線處理，全部必須透過 Cloud Functions。
      // Cloud Functions 使用 Admin SDK 寫入 Firestore，不受這份用戶端規則限制。
      allow read: if signedIn();
      allow create, update, delete: if false;

      match /actions/{actionId} {
        // 只允許登入玩家查看後端審計紀錄，不能由前端直接寫入。
        allow read: if signedIn();
        allow create, update, delete: if false;
      }
    }
  }
}
